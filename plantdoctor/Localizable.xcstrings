    "settings.icloud.message": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dein Verlauf wird nicht zwischen Geräten synchronisiert und nach einer Neuinstallation nicht wiederhergestellt. Melde dich in den Einstellungen bei iCloud an, um die Synchronisierung zu aktivieren."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Your history won’t sync across devices or survive reinstall. Sign in to iCloud in Settings to enable sync."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Tu historial no se sincronizará entre dispositivos ni se restaurará tras reinstalar. Inicia sesión en iCloud desde Ajustes para activar la sincronización."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Votre historique ne sera pas synchronisé entre vos appareils ni restauré après une réinstallation. Connectez-vous à iCloud dans les Réglages pour activer la synchronisation."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "履歴はデバイス間で同期されず、再インストール後も復元されません。同期を有効にするには、設定アプリで iCloud にサインインしてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "기록이 기기 간에 동기화되지 않으며 앱을 다시 설치해도 복원되지 않아요. 동기화를 활성화하려면 설정에서 iCloud에 로그인해 주세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "你的历史记录将不会同步到其他设备，也无法在重新安装后恢复。请在「设置」中登录 iCloud 以启用同步。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "你的歷史紀錄將不會同步到其他裝置，也無法在重新安裝後復原。請在「設定」中登入 iCloud 以啟用同步。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Seu histórico não será sincronizado entre dispositivos nem sobreviverá à reinstalação. Entre no iCloud nos Ajustes para ativar a sincronização."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "История не будет синхронизироваться между устройствами и не сохранится после переустановки. Войдите в iCloud в Настройках, чтобы включить синхронизацию."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "La cronologia non si sincronizzerà tra dispositivi né sopravviverà alla reinstallazione. Accedi a iCloud nelle Impostazioni per attivare la sincronizzazione."
          }
        }
      }
    },
