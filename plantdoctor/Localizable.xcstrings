    "result.rediagnose.subtitle": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Füge bis zu 2 weitere Fotos aus anderen Blickwinkeln hinzu und wir analysieren erneut. Verbraucht ein Guthaben."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add up to 2 more photos from different angles and we’ll re-analyze. Uses one credit."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Añade hasta 2 fotos más desde otros ángulos y volveremos a analizar. Consume un crédito."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajoutez jusqu’à 2 photos supplémentaires sous d’autres angles et nous relancerons l’analyse. Utilise un crédit."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "違う角度の写真を最大2枚追加して再分析できます。1回分のクレジットを使用します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "다른 각도의 사진을 최대 2장 추가해 다시 분석할 수 있어요. 크레딧 1회를 사용해요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "最多再添加 2 张不同角度的照片，我们将重新分析。消耗一次次数。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "最多再新增 2 張不同角度的照片，我們將重新分析。會消耗一次次數。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Adicione até 2 fotos em outros ângulos e faremos uma nova análise. Consome um crédito."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Добавьте до 2 фото с других ракурсов — мы повторим анализ. Использует 1 кредит."
          }
        },
        "it": {
          "stringUnit": {
