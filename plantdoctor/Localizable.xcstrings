          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "サブスクは App Store の設定で解約するまで毎月自動更新されます。クレジットパックは1回限りの購入です。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "구독은 App Store 설정에서 취소할 때까지 매월 자동 갱신돼요. 크레딧 팩은 일회성 구매예요."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "订阅每月自动续订，可在 App Store 设置中取消。积分包为一次性购买。"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
