    "error.authFailed": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Authentifizierung fehlgeschlagen. Bitte aktualisiere die App."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Authentication failed. Please update the app."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Error de autenticación. Actualiza la app."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Échec de l’authentification. Veuillez mettre à jour l’app."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "認証に失敗しました。アプリを更新してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "인증에 실패했어요. 앱을 업데이트해 주세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "身份验证失败。请更新应用。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "身份驗證失敗。請更新應用程式。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Falha na autenticação. Atualize o app."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Ошибка аутентификации. Обновите приложение."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Autenticazione non riuscita. Aggiorna l’app."
          }
        }
      }
    },
    "error.decoding": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wir haben eine unerwartete Antwort erhalten. Bitte versuche es erneut."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "We got an unexpected response. Please try again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Recibimos una respuesta inesperada. Inténtalo de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nous avons reçu une réponse inattendue. Réessayez."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "予期しない応答を受け取りました。もう一度お試しください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "예상치 못한 응답을 받았어요. 다시 시도해 주세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "收到意外响应。请重试。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "收到非預期的回應。請重試。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Recebemos uma resposta inesperada. Tente novamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Получен неожиданный ответ. Попробуйте ещё раз."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Abbiamo ricevuto una risposta imprevista. Riprova."
          }
        }
      }
    },
    "error.encodingFailed": {
      "extractionState": "manual",
      "localizations": {
        "de": {
