    "error.rateLimited.device": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du hast das stündliche Limit pro Gerät erreicht. Versuche es gleich nochmal."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You’ve hit the per-device hourly limit. Try again in a bit."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Has alcanzado el límite por dispositivo por hora. Vuelve a intentarlo pronto."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Limite horaire par appareil atteinte. Réessayez bientôt."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "1時間あたりの端末ごとの上限に達しました。しばらくしてお試しください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "기기당 시간당 한도에 도달했어요. 잠시 후 다시 시도하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已达到每台设备每小时上限。稍后重试。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "已達到每台裝置每小時上限。稍後重試。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Você atingiu o limite por hora neste dispositivo. Tente daqui a pouco."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Достигнут часовой лимит на устройстве. Повторите чуть позже."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Hai raggiunto il limite orario per dispositivo. Riprova tra poco."
          }
        }
      }
    },
    "error.rateLimited.global": {
      "extractionState": "manual",
      "localizations": {
