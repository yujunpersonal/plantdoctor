            "value": "Upgrade für tägliche Diagnosen oder Guthabenpakete kaufen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Upgrade for daily diagnoses, or top up with credit packs."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Mejora para diagnósticos diarios, o añade packs de créditos."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Passez à la version supérieure pour des diagnostics quotidiens, ou achetez des crédits."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アップグレードで毎日診断、またはクレジットパックで追加。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "업그레이드해 매일 진단하거나 크레딧 팩을 충전하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "升级享每日诊断，或购买积分包。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "升級享每日診斷，或購買點數包。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Faça upgrade para diagnósticos diários ou recarregue com pacotes de créditos."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Обновите план для ежедневных диагнозов или пополните кредиты."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Aggiorna per diagnosi giornaliere o ricarica con pacchetti di crediti."
          }
        }
      }
    },
