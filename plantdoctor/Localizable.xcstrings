    "paywall.legal.disclaimer": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Abos verlängern sich monatlich automatisch, bis sie in den App Store-Einstellungen gekündigt werden. Guthabenpakete sind Einmalkäufe."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Subscriptions auto-renew monthly until cancelled in App Store settings. Credit packs are one-time purchases."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Las suscripciones se renuevan automáticamente cada mes hasta que se cancelen en los ajustes del App Store. Los packs de créditos son compras únicas."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Les abonnements se renouvellent automatiquement chaque mois jusqu’à annulation dans les réglages de l’App Store. Les packs de crédits sont des achats uniques."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "サブスクは App Store の設定で解約するまで毎月自動更新されます。クレジットパックは1回限りの購入です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "구독은 App Store 설정에서 취소할 때까지 매월 자동 갱신돼요. 크레딧 팩은 일회성 구매예요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "订阅每月自动续订，可在 App Store 设置中取消。积分包为一次性购买。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "訂閱每月自動續訂，可在 App Store 設定中取消。點數包為一次性購買。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "As assinaturas renovam automaticamente todo mês até o cancelamento nas configurações da App Store. Pacotes de créditos são compras avulsas."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Подписка продлевается автоматически ежемесячно до отмены в настройках App Store. Пакеты кредитов — разовые покупки."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Gli abbonamenti si rinnovano automaticamente ogni mese fino all’annullamento nelle impostazioni dell’App Store. I pacchetti di crediti sono acquisti una tantum."
          }
        }
      }
    },
