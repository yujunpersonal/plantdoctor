    "error.offline": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Du scheinst offline zu sein. Prüfe deine Verbindung und versuche es erneut."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You appear to be offline. Check your connection and try again."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Parece que estás sin conexión. Comprueba tu conexión e inténtalo de nuevo."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous semblez hors ligne. Vérifiez votre connexion et réessayez."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "オフラインのようです。接続を確認してもう一度お試しください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "오프라인 상태예요. 연결을 확인하고 다시 시도하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "似乎已离线。请检查网络后重试。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "似乎已離線。請檢查網路後重試。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Você parece estar offline. Verifique sua conexão e tente novamente."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Похоже, вы не в сети. Проверьте подключение и попробуйте ещё раз."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Sembri offline. Controlla la connessione e riprova."
          }
        }
      }
    },
