            "state": "translated",
            "value": "Das Foto konnte nicht zum Upload vorbereitet werden. Versuche ein anderes Bild."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "We couldn’t prepare the photo for upload. Try a different image."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No pudimos preparar la foto para enviar. Prueba con otra imagen."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Impossible de préparer la photo pour l’envoi. Essayez une autre image."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "写真をアップロード用に準備できませんでした。別の画像をお試しください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "업로드할 사진을 준비할 수 없어요. 다른 이미지를 시도해 주세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "无法处理照片以上传。请尝试其他图片。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "無法處理照片以上傳。請嘗試其他圖片。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Não conseguimos preparar a foto para envio. Tente outra imagem."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Не удалось подготовить фото для отправки. Попробуйте другое изображение."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Non siamo riusciti a preparare la foto per il caricamento. Prova un’altra immagine."
          }
        }
      }
    },
