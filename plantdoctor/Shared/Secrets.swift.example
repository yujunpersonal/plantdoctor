// Copy to `Secrets.swift` and fill in real values.
// `Secrets.swift` is gitignored.
import Foundation

enum Secrets {
    /// Base URL of the deployed Cloudflare Worker. No trailing slash.
    static let apiBaseURL = URL(string: "https://plantdoctor-api.<account>.workers.dev")!

    /// Must match the backend `SHARED_SECRET` set via `wrangler secret put`.
    /// Rotate by redeploying both app and worker with a new value.
    static let sharedSecret = "REPLACE_WITH_64_CHAR_HEX"
}
